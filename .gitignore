# Secrets — never commit
.env
.env.*
!.env.example

# Ephemeral working directory
temp/

# Personal profile content (the directory itself + README + example are tracked,
# but the user's actual CV YAML and source PDF stay private by default).
profile/profile.md
profile/cv_source.pdf
profile/*.pdf

# Python virtual environment
.venv/

# Python build / cache artifacts
__pycache__/
*.py[cod]
*.egg-info/

# macOS
.DS_Store

# Editor
.vscode/
.idea/

# Claude Code memsearch cache
.memsearch/

# rendercv accidentally drops theme templates here when invoked from project root
classic/
markdown/
